---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import WaitlistForm from '../components/ui/WaitlistForm.astro';

const credentials = [
  { title: 'Harvard', body: 'Executive credential' },
  { title: 'MIT Sloan', body: 'Executive credential' },
  { title: 'Berkeley Haas', body: 'Executive credential' },
];

const previouslyPublished = [
  { title: 'Data Science Solutions', year: '2017' },
  { title: 'React Speed Coding', year: '2015' },
];
---
<Layout
  title="About — Stagent"
  description="Stagent is a personal research project by Manav Sehgal, exploring what an AI-native operating system looks like."
>
  <Nav />
  <main>
    <section class="relative overflow-hidden px-6 pt-32 pb-18">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-14 h-[26rem] w-[26rem] -translate-x-1/2 rounded-full bg-primary/[0.10] blur-[150px]"></div>
        <div class="absolute inset-x-0 bottom-0 h-40" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-5xl">
        <div data-animate>
          <SectionLabel text="About" />
        </div>
        <div class="mt-5 grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_18rem] lg:items-end">
          <div>
            <h1 data-animate class="font-display text-[clamp(2.2rem,6vw,4.5rem)] leading-[1.02]" style="transition-delay: 80ms">
              Manav Sehgal
            </h1>
            <p data-animate class="mt-5 max-w-3xl text-lg leading-relaxed text-text-muted" style="transition-delay: 160ms">
              Solutions Leader at AWS Frontier AI.
            </p>
          </div>

          <div data-animate class="rounded-2xl border border-border bg-surface-raised/80 p-5 shadow-[0_20px_80px_-40px_rgba(0,0,0,0.75)]" style="transition-delay: 220ms">
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-text-dim">A personal research project</p>
            <p class="mt-3 text-xl text-text">Stagent &amp; AI Native</p>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">
              Free and open source, in personal time and resources.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-border bg-surface-raised px-6 py-10">
      <div class="mx-auto grid max-w-6xl gap-4 md:grid-cols-3" data-animate-stagger>
        {credentials.map((card) => (
          <article data-animate class="rounded-2xl border border-border/70 bg-surface/80 p-5">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">{card.title}</p>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="px-6 py-18">
      <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[15rem_minmax(0,1fr)]">
        <aside data-animate class="lg:sticky lg:top-28 h-fit rounded-2xl border border-border bg-surface-raised/70 p-5">
          <p class="font-mono text-[0.62rem] uppercase tracking-[0.24em] text-text-dim">Short version</p>
          <p class="mt-4 text-sm leading-relaxed text-text-muted">
            Stagent is a personal research project exploring what an AI-native operating system looks like — the AI Native book is its 14-chapter playbook.
          </p>
        </aside>

        <div class="space-y-5" data-animate-stagger>
          <section data-animate class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
            <h2 class="text-2xl">Bio</h2>
            <p class="mt-4 text-base leading-relaxed text-text-muted">
              Manav is a solutions leader at AWS Frontier AI, collaborating with Anthropic, NVIDIA, and Disney on production agentic systems. His 25-year arc spans Xerox PARC (1996), HCL's digital practice, Amazon AGI, and AWS — where he has delivered generative AI solutions for Amazon Retail and Alexa and received a President of India award for an AWS pandemic response. He holds credentials from Harvard, MIT Sloan, and Berkeley Haas.
            </p>
          </section>

          <section data-animate class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
            <h2 class="text-2xl">Why Stagent</h2>
            <p class="mt-4 text-base leading-relaxed text-text-muted">
              Stagent is a personal research project exploring what an AI-native operating system looks like. The AI Native book is its 14-chapter playbook for building autonomous business systems with AI agents.
            </p>
          </section>

          <section data-animate class="rounded-2xl border border-primary/30 bg-primary/[0.03] p-6 sm:p-8">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-primary">Attribution</p>
            <p class="mt-4 text-base leading-relaxed text-text-muted">
              Stagent and AI Native are personal works of Manav Sehgal created in own personal time and resources. While they may refer to AWS technologies which enable the AI Native promise, the opinions expressed in the website are author's personal opinions and not that of the employer.
            </p>
          </section>

          <section data-animate class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
            <h2 class="text-2xl">Previously published</h2>
            <ul class="mt-4 space-y-3">
              {previouslyPublished.map((book) => (
                <li class="flex items-baseline gap-3 text-base text-text-muted">
                  <span class="text-text">{book.title}</span>
                  <span class="font-mono text-xs text-text-dim">({book.year})</span>
                </li>
              ))}
            </ul>
          </section>

          <section data-animate class="rounded-2xl border border-border bg-surface-raised/70 p-6 sm:p-8">
            <h2 class="text-2xl">Links</h2>
            <div class="mt-5 flex flex-wrap gap-3">
              <a
                href="https://github.com/manavsehgal/stagent.github.io"
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-6 py-3 hover:border-text-muted hover:text-primary transition-colors rounded-md"
              >
                GitHub
              </a>
              <a
                href="/book/"
                class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-6 py-3 hover:border-text-muted hover:text-primary transition-colors rounded-md"
              >
                Read the book
              </a>
            </div>

            <div class="mt-8">
              <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted mb-3">
                Subscribe to AI Native research
              </p>
              <WaitlistForm
                variant="cta"
                id="about-waitlist"
                source="research-newsletter"
                buttonText="Subscribe"
              />
            </div>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
